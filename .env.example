# Port the Express server listens on. Railway injects its own PORT at
# runtime; this default is only used for local development.
PORT=3000

# development | production
NODE_ENV=development

# PostgreSQL connection string.
# Local: postgresql://USER:PASSWORD@localhost:5432/DBNAME
# Production: copy the DATABASE_URL from the Railway Postgres service
# (Railway dashboard → Postgres service → Variables tab), then add it
# as a Variable Reference in the app service's Variables panel.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/abundance_architecture_dev"

# Secret key for signing JWT tokens. Use a long random string (32+ chars).
# Generate one with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-secret"

# Optional: fire-and-forget endpoint for contact form email notifications.
# Can be a Resend, SendGrid, or Formspree endpoint.
# If unset, contact messages are saved to the DB but no email is sent.
NOTIFICATION_EMAIL_ENDPOINT=

# Cloudflare Analytics (optional — enables the Analytics tab in admin).
# CF_ANALYTICS_TOKEN: Cloudflare → My Profile → API Tokens
#   Use "Read analytics for a zone" template, scoped to this domain only.
# CF_ZONE_ID and CF_ACCOUNT_ID: Cloudflare dashboard → domain overview → right sidebar.
CF_ANALYTICS_TOKEN=
CF_ZONE_ID=
CF_ACCOUNT_ID=

# Optional: enables top pages / referrers / device type data in analytics.
# Generate at Cloudflare Dashboard → Web Analytics → Add a site.
CF_WEB_ANALYTICS_SITE_TAG=
