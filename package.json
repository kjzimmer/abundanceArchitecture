{
  "name": "abundance-architecture-teaser",
  "version": "0.1.0",
  "description": "Abundance Architecture teaser landing page and Express server",
  "private": true,
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev:server": "tsx watch --env-file .env src/server.ts",
    "dev:admin": "vite --config admin/vite.config.ts",
    "dev": "tsx --env-file .env src/server.ts",
    "build": "prisma generate && tsc && vite build --config admin/vite.config.ts",
    "build:server": "prisma generate && tsc",
    "build:admin": "vite build --config admin/vite.config.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^17.4.2",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.21"
  }
}
