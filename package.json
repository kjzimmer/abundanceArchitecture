{
  "name": "abundance-architecture-teaser",
  "version": "0.1.0",
  "description": "Abundance Architecture — FoA suite monorepo",
  "private": true,
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "cd client && npm install && npm run build && cd ../server && npm install && npm run build",
    "start": "cd server && npm run start",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "seed:admin": "npx tsx server/src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "prisma": "^6.19.3"
  }
}
